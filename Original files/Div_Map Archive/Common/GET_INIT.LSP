			(if Cadet_HD
				(dos_setini (StpDot AppNam) "HD" Cadet_HD Fnam)
				(if Bug (princ "\nCadet_HD not defined!"))
			)
			(if _Path-Person
				(dos_setini (StpDot AppNam) "Person" _Path-Person Fnam)
				(if Bug (princ "\nPath-Person not defined!"))
			)
			(if _Path-Dwg
				(dos_setini (StpDot AppNam) "Dwg" _Path-Dwg Fnam)
				(if Bug (princ "\nPath-Dwg not defined!"))
			)
			(if _Path-Plot
				(dos_setini (StpDot AppNam) "Plot" _Path-Plot Fnam)
				(if Bug (princ "\nPath-Plot not defined!"))
