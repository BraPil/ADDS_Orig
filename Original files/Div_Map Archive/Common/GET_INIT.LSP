(defun ResetSPick01 (	Fnam /	MySndPick		; Re-creates PickBox keys in Acad14.cfg
							ChzInt CurPick )
	(if Bug (princ "\n{ResetSPick01 Entered"))
	(if SndPick01
		(setq	CurPick	SndPick01
				ChzInt	-3
		)
		(setq	CurPick	10
				ChzInt	-3
		)
	)
	(initget 1 "View")
	(if (null MyLst)
		(RWav nil)
	)
	(if (and MyLst Fnam)
		(while (or (< ChzInt -1) (> ChzInt (length MyLst)) (= ChzInt "View"))
			(setq	ChzInt	(getint (strcat "\nWhat would you like to set your StartUp Sound file to? (<V>iew list, <-1> for No Sound or sound number [" (itoa (1+ CurPick)) "]): ")))
			(if (= ChzInt "View")
				(textscr)
			)
			(if (= ChzInt "View")
				(terpri)
			)
			(if (= ChzInt "View")
				(princ	(strcat	"\n"
								(PadCharR (itoa -1) 3)
								(PadCharR	"No Sound" 16)
								"No Sound at all"
						)
				)
			)
			(if (= ChzInt "View")
				(princ	(strcat	"\n"
								(PadCharR (itoa 0) 3)
								(PadCharR	"Random" 16)
								"Any sound on the list from 11-37"
						)
				)
			)
			(if (= ChzInt "View")
				(foreach	WavOne
						MyLst
						(princ	(strcat	"\n"
										(PadCharR (itoa (1+ (nth 1 WavOne))) 3)
										(PadCharR	(nth 0 WavOne) 16)
										(nth 2 WavOne)
								)
						)
				)
			)
			(if (= ChzInt "View")
				(setq	ChzInt	-3)
				(if (or (< ChzInt -1) (> ChzInt (length MyLst)))
					(setq	Bubba	(princ "\nYour value was invalid... try again.\n")
							ChzInt	-3
					)
				)
			)
			(if (and (>= ChzInt -1) (<= ChzInt (length MyLst)))
				(progn
					(if (not (= (dos_getini (StpDot AppNam) "SndPick01Test" Fnam) "1"))
						(dos_setini (StpDot AppNam) "SndPick01Test" "1" Fnam)
					)
					(dos_setini (StpDot AppNam) "SndPick01Val" (itoa (1- ChzInt)) Fnam)
					(setq	SndPick01		(1- ChzInt))
					(cond
						((and (> ChzInt 0) (<= ChzInt (length MyLst)))
							(princ (strcat "\nIt's sound number: <" (itoa ChzInt) ">, and it sounds like this:"))
						)
						((= ChzInt 0)
							(princ (strcat "\nIt's the Random Sound number: <" (itoa ChzInt) ">, and it can sound like this:"))
						)
						((= ChzInt -1)
							(princ (strcat "\nIt's the No Sound number: <" (itoa ChzInt) ">, and it sounds like this: <grin>"))
						)
						((< ChzInt -1)
							(princ (strcat "\nIt's the Say What? Sound number: <" (itoa ChzInt) ">, and it sounds like this: <grin>"))
						)
					)
					
					(RWav SndPick01)
					(princ)
				)
			)
		)
	)
	(if Bug (princ "\nResetSPick01 Exited}\n"))
	(princ)
)

