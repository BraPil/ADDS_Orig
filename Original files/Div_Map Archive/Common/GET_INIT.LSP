				(= (StpDot AppNam) "SUBTOOLS")
				(wcmatch (StpDot AppNam) "ADDS##")
			)
		)
		(DivDevGet Div)
	)
)

(defun Upd_INI ( / Fnam Bubba PthLst )			; Updates INI file paths
	(if Bug (princ "\nGet_Init.Lsp!Upd_Ini - Entered\n"))
	(setq	Fnam	(Find_INI))
	(if (and Bug Fnam)
		(princ (strcat "\nINI file: " Fnam))
	)
	(if (and Bug _Path-Person)
		(princ (strcat "\nPersonal Dir: " _Path-Person))
	)
	(if Fnam
		(setq	PthLst	(PathDlg))
		(if _Path-Person
			(setq	Fnam		(strcat _Path-Person "DIV_MAP.INI")
					PthLst	(PathDlg)
			)
			(setq	PthLst	nil)
		)
	)
	(if (and Bug _Path-Person)
		(princ (strcat "\nPersonal Dir: " _Path-Person))
	)
	(cond
		((and PthLst (= (StpDot AppNam) "ADDSPLOT") (not DevMark))
			(setq    	Bubba	(dos_setini "ADDSPLOT" "UserName" Adds_User Fnam)
