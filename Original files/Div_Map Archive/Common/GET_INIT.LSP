(defun UpdDivINI ( Def	/	Bubba Cnt InData	; Updates INI file paths to Divisions
						Hdr x Fn F0 F1 Dsc DivINI
						Div_Lst TDiv Div_Pth TmpDiv )
	(if PanLst
		(if (/= (AddsQuit 2) 2)
			(setq	Bubba	(alert "You can't change Divisions with Panels open, you know.")
					Bubba	(exit)
			)
		)
	)
	(setq	DivINI	(strcat _Path-Person "DIV_MAP.INI")
			Div_Lst	(list	"BH" "S_" "W_" "E_" "M_" "SE" "AL" "GA")
			TDiv		nil
			Div_Pth	(list	nil nil nil nil nil nil nil nil)
	)
	(if (findfile DivINI)
		(progn
			(if (setq TmpDiv (dos_getini (StpDot AppNam) (strcat "BH" ".DIVISION") DivINI))
				(if (= (substr TmpDiv 1 1) "*")
					(setq	Div_Pth	(RepLst Div_Pth (cons "BH" (substr TmpDiv 2)) 0)
							TDiv		0
					)
					(setq	Div_Pth	(RepLst Div_Pth (cons "BH" TmpDiv) 0))
				)
				(setq	Div_Pth	(RepLst Div_Pth (cons "BH" "") 0))
			)
			(if (setq TmpDiv (dos_getini (StpDot AppNam) (strcat "S_" ".DIVISION") DivINI))
				(if (= (substr TmpDiv 1 1) "*")
					(setq	Div_Pth	(RepLst Div_Pth (cons "S_" (substr TmpDiv 2)) 1)
							TDiv		1
					)
					(setq	Div_Pth	(RepLst Div_Pth (cons "S_" TmpDiv) 1))
				)
				(setq	Div_Pth	(RepLst Div_Pth (cons "S_" "") 1))
			)
			(if (setq TmpDiv (dos_getini (StpDot AppNam) (strcat "W_" ".DIVISION") DivINI))
				(if (= (substr TmpDiv 1 1) "*")
					(setq	Div_Pth	(RepLst Div_Pth (cons "W_" (substr TmpDiv 2)) 2)
							TDiv		2
					)
					(setq	Div_Pth	(RepLst Div_Pth (cons "W_" TmpDiv) 2))
				)
				(setq	Div_Pth	(RepLst Div_Pth (cons "W_" "") 2))
			)
			(if (setq TmpDiv (dos_getini (StpDot AppNam) (strcat "E_" ".DIVISION") DivINI))
				(if (= (substr TmpDiv 1 1) "*")
					(setq	Div_Pth	(RepLst Div_Pth (cons "E_" (substr TmpDiv 2)) 3)
							TDiv		3
					)
					(setq	Div_Pth	(RepLst Div_Pth (cons "E_" TmpDiv) 3))
				)
				(setq	Div_Pth	(RepLst Div_Pth (cons "E_" "") 3))
			)
			(if (setq TmpDiv (dos_getini (StpDot AppNam) (strcat "M_" ".DIVISION") DivINI))
				(if (= (substr TmpDiv 1 1) "*")
					(setq	Div_Pth	(RepLst Div_Pth (cons "M_" (substr TmpDiv 2)) 4)
							TDiv		4
					)
					(setq	Div_Pth	(RepLst Div_Pth (cons "M_" TmpDiv) 4))
				)
				(setq	Div_Pth	(RepLst Div_Pth (cons "M_" "") 4))
			)
			(if (setq TmpDiv (dos_getini (StpDot AppNam) (strcat "SE" ".DIVISION") DivINI))
				(if (= (substr TmpDiv 1 1) "*")
					(setq	Div_Pth	(RepLst Div_Pth (cons "SE" (substr TmpDiv 2)) 5)
							TDiv		5
					)
					(setq	Div_Pth	(RepLst Div_Pth (cons "SE" TmpDiv) 5))
				)
				(setq	Div_Pth	(RepLst Div_Pth (cons "SE" "") 5))
			)
			
			(if (setq TmpDiv (dos_getini (StpDot AppNam) (strcat "AL" ".DIVISION") DivINI))
				(if (= (substr TmpDiv 1 1) "*")
					(setq	Div_Pth	(RepLst Div_Pth (cons "AL" (substr TmpDiv 2)) 6)
							TDiv		5
					)
					(setq	Div_Pth	(RepLst Div_Pth (cons "AL" TmpDiv) 6))
				)
				(setq	Div_Pth	(RepLst Div_Pth (cons "AL" "") 6))
			)
			(if (setq TmpDiv (dos_getini (StpDot AppNam) (strcat "GA" ".DIVISION") DivINI))
				(if (= (substr TmpDiv 1 1) "*")
					(setq	Div_Pth	(RepLst Div_Pth (cons "GA" (substr TmpDiv 2)) 7)
							TDiv		5
					)
					(setq	Div_Pth	(RepLst Div_Pth (cons "GA" TmpDiv) 7))
				)
				(setq	Div_Pth	(RepLst Div_Pth (cons "GA" "") 7))
			)
			
			(setq	Dlg	2)
		)
	)
	(if Def
		(if (member (strcase Def) Div_Lst)
			(setq	Div	(strcase Def)
					dlg	1
					XPanel 	(if (= Div "AL") 
								60000
								6000
							)
					YPanel 	(if (= Div "AL") 
								40000
								4000
							)
			)
;;;			(setq	Div	nil)
			(if (setq Dcl_Pan (findfile "Get_Init.dcl"))
				(if (> (setq Dcl_Pan (load_dialog Dcl_Pan)) 0)
					(while (> dlg 1)
						(new_dialog "DivPath" Dcl_Pan)
						(set_tile "Pth0" (cdr (nth 0 Div_Pth)))
						(set_tile "Pth1" (cdr (nth 1 Div_Pth)))
						(set_tile "Pth2" (cdr (nth 2 Div_Pth)))
						(set_tile "Pth3" (cdr (nth 3 Div_Pth)))
						(set_tile "Pth4" (cdr (nth 4 Div_Pth)))
						(set_tile "Pth5" (cdr (nth 5 Div_Pth)))
						(set_tile "Pth6" (cdr (nth 6 Div_Pth)))
						(set_tile "Pth7" (cdr (nth 7 Div_Pth)))
						(cond	((= Div "BH")
									(set_tile "Ch0" "1")
									(setq TDiv (Cb_Ch Div_Pth "1" 0))
								)
								((= Div "S_")
									(set_tile "Ch1" "1")
									(setq TDiv (Cb_Ch Div_Pth "1" 1))
								)
								((= Div "W_")
									(set_tile "Ch2" "1")
									(setq TDiv (Cb_Ch Div_Pth "1" 2))
								)
								((= Div "E_")
									(set_tile "Ch3" "1")
									(setq TDiv (Cb_Ch Div_Pth "1" 3))
								)
								((= Div "M_")
									(set_tile "Ch4" "1")
									(setq TDiv (Cb_Ch Div_Pth "1" 4))
								)
								((= Div "SE")
									(set_tile "Ch5" "1")
									(setq TDiv (Cb_Ch Div_Pth "1" 5))
								)
								
								((= Div "AL")
									(set_tile "Ch6" "1")
									(setq TDiv (Cb_Ch Div_Pth "1" 6))
								)
								((= Div "GA")
									(set_tile "Ch7" "1")
									(setq TDiv (Cb_Ch Div_Pth "1" 7))
								)
						)
						(action_tile "Pth0" "(setq Div_Pth (Cb_Pth Div_Pth $value 0))")
						(action_tile "Pth1" "(setq Div_Pth (Cb_Pth Div_Pth $value 1))")
						(action_tile "Pth2" "(setq Div_Pth (Cb_Pth Div_Pth $value 2))")
						(action_tile "Pth3" "(setq Div_Pth (Cb_Pth Div_Pth $value 3))")
						(action_tile "Pth4" "(setq Div_Pth (Cb_Pth Div_Pth $value 4))")
						(action_tile "Pth5" "(setq Div_Pth (Cb_Pth Div_Pth $value 5))")
						(action_tile "Pth6" "(setq Div_Pth (Cb_Pth Div_Pth $value 6))")
						(action_tile "Pth7" "(setq Div_Pth (Cb_Pth Div_Pth $value 7))")
						(action_tile "Ch0" "(setq TDiv (Cb_Ch Div_Pth $value 0))")
						(action_tile "Ch1" "(setq TDiv (Cb_Ch Div_Pth $value 1))")
						(action_tile "Ch2" "(setq TDiv (Cb_Ch Div_Pth $value 2))")
						(action_tile "Ch3" "(setq TDiv (Cb_Ch Div_Pth $value 3))")
						(action_tile "Ch4" "(setq TDiv (Cb_Ch Div_Pth $value 4))")
						(action_tile "Ch5" "(setq TDiv (Cb_Ch Div_Pth $value 5))")
						
						(action_tile "Ch6" "(setq TDiv (Cb_Ch Div_Pth $value 6))")
						(action_tile "Ch7" "(setq TDiv (Cb_Ch Div_Pth $value 7))")
						
						(action_tile "ok_button" "(done_dialog 1)")
						(setq dlg (start_dialog))
						(unload_dialog Dcl_Pan)
					)
					(alert "\nUnable to open DCL file")
				)
				(alert "\nUnable to find DCL file")
			)
		)
	)
	(if (and (= dlg 1) (not DevMark))
;	(if (= dlg 1)
		(progn
			(if (findfile DivINI)
				(progn
					(if (> (strlen (cdr (nth 0 Div_Pth))) 1)
						(if (= Div "BH")
							(dos_setini (StpDot AppNam) (strcat "BH" ".DIVISION") (strcat "*" (cdr (nth 0 Div_Pth))) DivINI)
							(dos_setini (StpDot AppNam) (strcat "BH" ".DIVISION") (cdr (nth 0 Div_Pth)) DivINI)
						)
					)
					(if (> (strlen (cdr (nth 1 Div_Pth))) 1)
						(if (= Div "S_")
							(dos_setini (StpDot AppNam) (strcat "S_" ".DIVISION") (strcat "*" (cdr (nth 1 Div_Pth))) DivINI)
							(dos_setini (StpDot AppNam) (strcat "S_" ".DIVISION") (cdr (nth 1 Div_Pth)) DivINI)
						)
					)
					(if (> (strlen (cdr (nth 2 Div_Pth))) 1)
						(if (= Div "W_")
							(dos_setini (StpDot AppNam) (strcat "W_" ".DIVISION") (strcat "*" (cdr (nth 2 Div_Pth))) DivINI)
							(dos_setini (StpDot AppNam) (strcat "W_" ".DIVISION") (cdr (nth 2 Div_Pth)) DivINI)
						)
					)
					(if (> (strlen (cdr (nth 3 Div_Pth))) 1)
						(if (= Div "E_")
							(dos_setini (StpDot AppNam) (strcat "E_" ".DIVISION") (strcat "*" (cdr (nth 3 Div_Pth))) DivINI)
							(dos_setini (StpDot AppNam) (strcat "E_" ".DIVISION") (cdr (nth 3 Div_Pth)) DivINI)
						)
					)
					(if (> (strlen (cdr (nth 4 Div_Pth))) 1)
						(if (= Div "M_")
							(dos_setini (StpDot AppNam) (strcat "M_" ".DIVISION") (strcat "*" (cdr (nth 4 Div_Pth))) DivINI)
							(dos_setini (StpDot AppNam) (strcat "M_" ".DIVISION") (cdr (nth 4 Div_Pth)) DivINI)
						)
					)
					(if (> (strlen (cdr (nth 5 Div_Pth))) 1)
						(if (= Div "SE")
							(dos_setini (StpDot AppNam) (strcat "SE" ".DIVISION") (strcat "*" (cdr (nth 5 Div_Pth))) DivINI)
							(dos_setini (StpDot AppNam) (strcat "SE" ".DIVISION") (cdr (nth 5 Div_Pth)) DivINI)
						)
					)
					
					(if (> (strlen (cdr (nth 5 Div_Pth))) 1)
						(if (= Div "AL")
							(dos_setini (StpDot AppNam) (strcat "AL" ".DIVISION") (strcat "*" (cdr (nth 6 Div_Pth))) DivINI)
							(dos_setini (StpDot AppNam) (strcat "AL" ".DIVISION") (cdr (nth 6 Div_Pth)) DivINI)
						)
					)
					(if (> (strlen (cdr (nth 5 Div_Pth))) 1)
						(if (= Div "GA")
							(dos_setini (StpDot AppNam) (strcat "GA" ".DIVISION") (strcat "*" (cdr (nth 7 Div_Pth))) DivINI)
							(dos_setini (StpDot AppNam) (strcat "GA" ".DIVISION") (cdr (nth 7 Div_Pth)) DivINI)
						)
					)
				)
			)
			(if Div
				(progn
					(setq	_Path-Div		(cdr (assoc Div Div_Pth))
							_PATH-PANEL	_Path-Div
							Bubba		(setvar "USERS3" Div)
					)
					(cond	((= Div "BH") (princ "\nBirmingham Division Selected"))
							((= Div "S_") (princ "\nSouthern Division Selected"))
							((= Div "W_") (princ "\nWestern Division Selected"))
							((= Div "E_") (princ "\nEastern Division Selected"))
							((= Div "N_") (princ "\nNorthern Division Selected"))
							((= Div "SE") (princ "\nSouth-Eastern Division Selected"))
							
							((= Div "AL") (princ "\nTransmission - Alabama Control Center Selected"))
							((= Div "GA") (princ "\nTransmission - Georgia Control Center Selected"))
			
					)
					(if (= (strcase (substr _Path-Panel 1 1)) "S")
						(UpdPanPth _Path-Panel)
					)
					(if Lst_Fd_XY
						(setq	Lst_Fd_XY		nil)
					)
					(if Lst_Sb_XY
						(setq	Lst_Sb_XY		nil)
					)
					(if Lst_Fd_Nam
						(setq	Lst_Fd_Nam	nil)
					)
					(if Lst_Sb_Nam
						(setq	Lst_Sb_Nam	nil)
					)
					(Bld_T_Fdr)
				)
			)
			(princ "\nDiv Paths/Choice Updated!")
		)
		(if DevMark
			(progn
				(setq	Bubba		(setvar "USERS3" Div))
				(princ "\nPt1 Division :")(prin1 Div)
				(DivDevGet Div)
				(cond	((= Div "BH") (princ "\nBirmingham Division Selected"))
						((= Div "S_") (princ "\nSouthern Division Selected"))
						((= Div "W_") (princ "\nWestern Division Selected"))
						((= Div "E_") (princ "\nEastern Division Selected"))
						((= Div "N_") (princ "\nNorthern Division Selected"))
						((= Div "SE") (princ "\nSouth-Eastern Division Selected"))
						
						((= Div "AL") (princ "\nTransmission - Alabama Control Center Selected"))
