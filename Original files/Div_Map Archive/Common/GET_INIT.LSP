(defun Cb_Pth ( Div_Pth PVal PPos / Tstr TVal )	; Call Back function to test paths of Divisions
	(setq	Tstr		(list nil "" " " "  " "   " "    " "     "))
	(if (not (member PVal Tstr))
		(if (TstPth (dos_splitpath PVal))
			(setq	TVal		(strcase PVal))
			(setq	TVal		" ")
		)
		(setq	TVal	" ")
	)
	(setq	Div_Pth	(RepLst Div_Pth (cons (car (nth PPos Div_Pth)) TVal) PPos))
	(cond	((= PPos 0) (set_tile "Pth0" (strcase TVal)))
			((= PPos 1) (set_tile "Pth1" (strcase TVal)))
			((= PPos 2) (set_tile "Pth2" (strcase TVal)))
			((= PPos 3) (set_tile "Pth3" (strcase TVal)))
			((= PPos 4) (set_tile "Pth4" (strcase TVal)))
			((= PPos 5) (set_tile "Pth5" (strcase TVal)))
	)
	(cond	((= (get_tile "Ch0") "1") (setq TPos 0))
			((= (get_tile "Ch1") "1") (setq TPos 1))
			((= (get_tile "Ch2") "1") (setq TPos 2))
			((= (get_tile "Ch3") "1") (setq TPos 3))
			((= (get_tile "Ch4") "1") (setq TPos 4))
			((= (get_tile "Ch5") "1") (setq TPos 5))
			(T (setq TPos 6))
	)
	(if	(and	(or	(member (get_tile "Pth0") Tstr) (> (strlen (cdr (nth 0 Div_Pth))) 1))
			(or	(member (get_tile "Pth1") Tstr) (> (strlen (cdr (nth 1 Div_Pth))) 1))
			(or	(member (get_tile "Pth2") Tstr) (> (strlen (cdr (nth 2 Div_Pth))) 1))
			(or	(member (get_tile "Pth3") Tstr) (> (strlen (cdr (nth 3 Div_Pth))) 1))
			(or	(member (get_tile "Pth4") Tstr) (> (strlen (cdr (nth 4 Div_Pth))) 1))
			(or	(member (get_tile "Pth5") Tstr) (> (strlen (cdr (nth 5 Div_Pth))) 1))
			(and (>= TPos 0) (<= TPos 5))
		)
		(mode_tile "ok_button" 0)
		(mode_tile "ok_button" 1)
	)
	Div_Pth
)

