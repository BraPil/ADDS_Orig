(defun MultDlg ( M1 M2 /	dlg				; Big INI Path set function
						Dcl_Pan M1_Lst M2_Lst )
	(setq	dlg		2)
	(if M1
		(setq	M1_Lst	(rtos (* 100.0 M1) 2 0))
		(setq	M1_Lst	"100")
	)
	(if M2
		(setq	M2_Lst	(rtos (* 100.0 M2) 2 0))
		(setq	M2_Lst	"100")
	)
	(if (setq Dcl_Pan (findfile "Get_Init.dcl"))
		(if (> (setq Dcl_Pan (load_dialog Dcl_Pan)) 0)
			(while (> dlg 1)
				(new_dialog "INIMult" Dcl_Pan)
				(set_tile "TM_EDIT" (strcat M1_Lst "%"))
				(set_tile "TM_SLDR" M1_Lst)
				(set_tile "SM_EDIT" (strcat M2_Lst "%"))
				(set_tile "SM_SLDR" M2_Lst)
				(if (and M1_Lst Bug) (princ (strcat "\nTMult set to: " M1_Lst)))
				(if (and M2_Lst Bug) (princ (strcat "\nSMult set to: " M2_Lst)))
				(action_tile "TM_SLDR" "(setq M1_Lst $value)(set_tile \"TM_EDIT\" (strcat $value (chr 37)))")
				(action_tile "TM_EDIT" "(setq M1_Lst $value)(set_tile \"TM_SLDR\" (if (= (substr $value 1 4) (chr 37)) (substr $value 1 3) $value))")
				(action_tile "SM_SLDR" "(setq M2_Lst $value)(set_tile \"SM_EDIT\" (strcat $value (chr 37)))")
				(action_tile "SM_EDIT" "(setq M2_Lst $value)(set_tile \"SM_SLDR\" (if (= (substr $value 1 4) (chr 37)) (substr $value 1 3) $value))")
				(action_tile "ok_button" "(done_dialog 1)")
				(action_tile "cancel_button" "(done_dialog 0)")
				(setq dlg (start_dialog))
				(unload_dialog Dcl_Pan)
			)
			(alert "\nUnable to open DCL file")
		)
		(alert "\nUnable to find DCL file")
	)
	(if (> dlg 0)
		(progn
			(if M1_Lst (setq TMult (/ (float (atoi M1_Lst)) 100.0)))
			(if (and M1_Lst Bug)
				(princ (strcat "\nTMult set to: " M1_Lst))
			)
			(if M2_Lst (setq SMult (/ (float (atoi M2_Lst)) 100.0)))
			(if (and M2_Lst Bug)
				(princ (strcat "\nSMult set to: " M2_Lst))
			)
			(if _Path-Person
				(setq	MultINI	(strcat _Path-Person "DIV_MAP.INI"))
				(setq	MultINI	(Find_INI))
			)
			(cond 
				((and (= (StpDot AppNam) "ADDS")	(not DevMark))			
					(setq	AppKey 	"ADDS")
				)
				((and (= (StpDot AppNam) "ADDSPLOT") (not DevMark))
					(setq	AppKey 	"ADDSPLOT")
				)
			)
			(setq	Bubba	(dos_setini AppKey "TMult" (rtos (* 100.0 TMult) 2 0) MultINI)
					Bubba	(dos_setini AppKey "SMult" (rtos (* 100.0 SMult) 2 0) MultINI)
			)
		)
	)
	(princ)
)

(defun PathDlg ( /	dlg Cnt HdVal NdVal NamVal	; INI Path Dialog
				DrLst Dcl_Pan ActLst GoPath DosLibVer )	;;;	CET 07/26/2007 Added DosLib

;;;	CET 07/26/2007 Added Select to handle AutoCAD 2007 place before Application name check because same basic code block
;;; 			was repeated for each application.

;;;	Check and load correct version of Dos Library functions if need.
	(cond 
		((= (substr (getvar "ACADVER") 1 4) "24.2")	;	AutoCAD 2023
			(setq DosLibVer "DOSLib24x64.arx")
		)
		((= (substr (getvar "ACADVER") 1 4) "23.0")	;	AutoCAD 2019
			(setq DosLibVer "DOSLib23x64.arx")
		)
		((= (substr (getvar "ACADVER") 1 4) "20.1")	;	AutoCAD 2016
			(setq DosLibVer "DOSLib20x64.arx")
		)
		((= (substr (getvar "ACADVER") 1 4) "18.2")	;	AutoCAD 2012
			(setq DosLibVer "DosLib18x64.arx")
		)
		((= (substr (getvar "ACADVER") 1 4) "17.0")	;	AutoCAD 2007
			(setq DosLibVer "doslib17.arx")
		)
		((= (getvar "ACADVER") "15.0")			;	AutoCAD 2000
			(setq DosLibVer "doslib2k.arx")
		)
		(T
			(setq DosLibVer "doslib14.arx")
		)
	)
 	(if DosLibVer
		(if (not (member (strcase DosLibVer T) (arx)))
			(if (findfile DosLibVer)
				(arxload DosLibVer)
				(princ "\n*Buttons Error*: DosLIB Arx file not found on this system!")
			)
		)
	)
;;;	Initialize common variables for all applications.
	(setq	dlg		2
			Cnt		65
			HdVal	nil
			NdVal	nil
			NamVal	nil
			DrLst	(dos_drives)
			ActLst	(list nil nil nil)
	)
;;;	Check to see which Application is running and makes application specific selection, setting, actions, etc.	
	(cond
		((or (wcmatch (StpDot AppNam) "CADET##")(=(StpDot AppNam) "CADET"))
;;; CET 07/26/2007 Removed If statements replaced with select before repeat same calls.			
			(if Cadet_Net
				(setq	NdVal	(substr Cadet_Net 1 2)
						NdVal	(- (length DrLst) (length (member NdVal DrLst)))
						NdVal	(itoa NdVal)
				)
			)
			(if Cadet_HD
				(setq	HdVal	(substr Cadet_HD 1 2)
						HdVal	(- (length DrLst) (length (member HdVal DrLst)))
						HdVal	(itoa HdVal)
				)
			)
			(if (setq Dcl_Pan (findfile "Get_Init.dcl"))
				(if (> (setq Dcl_Pan (load_dialog Dcl_Pan)) 0)
					(while (> dlg 1)
						(new_dialog "INIEditCadet" Dcl_Pan)
						(start_list "Lst1" 3)
						(mapcar (quote add_list) DrLst)
						(end_list)
						(start_list "Lst2" 3)
						(mapcar (quote add_list) DrLst)
						(end_list)
						(if HdVal
							(set_tile "Lst1" HdVal)
						)
						(if NdVal
							(set_tile "Lst2" NdVal)
						)
						(if Cadet_User
							(set_tile "Str3" Cadet_User)
							(if (getenv "USERNAME")
								(set_tile "Str3" (getenv "USERNAME"))
								(set_tile "Str3" (strcase (getvar "loginname")))
							)
						)
						(if (and HdVal NdVal Cadet_User)
							(setq	ActLst	(list	(get_tile "Lst1")
													(get_tile "Lst2")
													(get_tile "Str3")
											)
							)
						)
						(Cb_Ok nil nil ActLst)
						(action_tile "Lst1" "(setq ActLst (Cb_Ok 1 $value ActLst))")
						(action_tile "Lst2" "(setq ActLst (Cb_Ok 2 $value ActLst))")
						(action_tile "Str3" "(setq ActLst (Cb_Ok 3 $value ActLst))")
						(action_tile "ok_button" "(done_dialog 1)")
						(setq dlg (start_dialog))
						(unload_dialog Dcl_Pan)
					)
					(alert "\nUnable to open DCL file")
				)
				(alert "\nUnable to find DCL file")
			)
			(if (and (nth 0 ActLst) (nth 1 ActLst) (nth 2 ActLst))
				(progn
					(if (or (not Cadet_HD) (= Cadet_HD "default"))
						(if	(member "CADET20" (mapcar (quote strcase) (dos_subdir (strcat (nth (atoi (nth 0 ActLst)) DrLst) "\\"))))
							(setq	Cadet_HD		(strcat (nth (atoi (nth 0 ActLst)) DrLst) "\\CADET20\\"))
							(setq	Cadet_HD		(strcat (nth (atoi (nth 0 ActLst)) DrLst) "\\"))
						)
					)
					(if (or (not Cadet_Old) (= Cadet_Old "default"))
						(if (member "CADET" (mapcar (quote strcase) (dos_subdir (strcat (nth (atoi (nth 1 ActLst)) DrLst) "\\"))))
							(setq	Cadet_Old	(strcat (nth (atoi (nth 1 ActLst)) DrLst) "\\CADET\\"))
							(setq	Cadet_Old	(strcat (nth (atoi (nth 1 ActLst)) DrLst) "\\"))
						)
					)
					(if (or (not Cadet_Net) (= Cadet_Net "default"))
						(progn
							(if (member "DIVMAP10" (mapcar (quote strcase) (dos_subdir (strcat (nth (atoi (nth 1 ActLst)) DrLst) "\\"))))
								(setq	Cadet_Net	(strcat (nth (atoi (nth 1 ActLst)) DrLst) "\\DIVMAP10\\"))
								(setq	Cadet_Net	(strcat (nth (atoi (nth 1 ActLst)) DrLst) "\\"))
							)
							(if (member "CADET20" (mapcar (quote strcase) (dos_subdir Cadet_Net)))
								(setq	Cadet_Net		(strcat Cadet_Net "CADET20\\"))
								(setq	Cadet_Net		(strcat Cadet_Net))
							)
						)
					)
					(setq	Cadet_User	(nth 2 ActLst))
					(if (not _Path-Dwg)
						(if (member "DWG" (mapcar (quote strcase) (dos_subdir Cadet_Old)))
							(setq	_Path-Dwg		(strcat Cadet_Old "DWG\\"))
							(setq	_Path-Dwg		(strcat Cadet_Old))
						)
					)
					(if (not _Path-Plot)
						(if (member "PLOT" (mapcar (quote strcase) (dos_subdir Cadet_Old)))
							(setq	_Path-Plot	(strcat Cadet_Old "PLOT\\"))
							(setq	_Path-Plot	(strcat Cadet_Old))
						)
					)
					(if (not _Path-User)
						(if (member "USER" (mapcar (quote strcase) (dos_subdir Cadet_Old)))
							(setq	_Path-User	(strcat Cadet_Old "USER\\"))
							(setq	_Path-User	(strcat Cadet_Old))
						)
					)
					(if (not _Path-Lisp)
						(if (member "LISP" (mapcar (quote strcase) (dos_subdir Cadet_Net)))
							(setq	_Path-Lisp	(strcat Cadet_Net "LISP\\"))
							(setq	_Path-Lisp	(strcat Cadet_Net))
						)
					)
					(if (not _Path-LUT)
						(if (member "LUT" (mapcar (quote strcase) (dos_subdir Cadet_Net)))
							(setq	_Path-LUT		(strcat Cadet_Net "LUT\\"))
							(setq	_Path-LUT		(strcat Cadet_Net))
						)
					)
					(if (not _Path-Menu)
						(if (member "MENU" (mapcar (quote strcase) (dos_subdir Cadet_Net)))
							(setq	_Path-Menu	(strcat Cadet_Net "MENU\\"))
							(setq	_Path-Menu	(strcat Cadet_Net))
						)
					)
					(if (not _Path-Sym)
						(if (member "SYM" (mapcar (quote strcase) (dos_subdir Cadet_Net)))
							(setq	_Path-Sym		(strcat Cadet_Net "SYM\\"))
							(setq	_Path-Sym		(strcat Cadet_Net))
						)
					)
					;	Populates list for intial values in path dialog box later in this function.
					(setq	PthLst	(list	_Path-Person	;  0 INI Section -
											Cadet_HD		;  1 INI Section -
											_Path-Dwg		;  2 INI Section -
											_Path-Plot	;  3 INI Section -
											_Path-User	;  4 INI Section -
											_Path-Lisp	;  5 INI Section -
											_Path-LUT		;  6 INI Section -
											_Path-Menu	;  7 INI Section -
											_Path-Sym		;  8 INI Section -
									)
					)
					(setq	GoPath	T
							dlg		2
					)
				)
			)
		)
		((= (StpDot AppNam) "ADDS")
				(progn
					(princ "\n - PathDlg - start")
					
					(cond 
						((= Div "AL")
							setq	Adds_Net		(strcat "S:\\WorkGroups\\" (DecodeDivisionPath) "\\Transmap\\ADDS_TMap\\"(StpDot AppNam) "\\")
						)
						((= Div "GA")
							setq	Adds_Net		(strcat "S:\\WorkGroups\\" (DecodeDivisionPath) "\\STAFF\\Transmap\\ADDS_TMap\\"(StpDot AppNam) "\\")
						)
						(t
							setq	Adds_Net		(strcat "S:\\WorkGroups\\" (DecodeDivisionPath) "\\Division Mapping\\"(StpDot AppNam) "\\")
						)
					)	
							
				    (setq		Adds_Local	"C:\\Div_Map\\"
							Adds_HD		(strcat "C:\\" (StpDot AppNam) "\\")
					)
					
					;	This section builds default path if _Path-xxx does not exists.
					(if (not _Path-Person)
						(setq	_Path-Person	Adds_Local)
					)
