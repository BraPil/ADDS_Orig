(defun DecodeTargetPathDwf ( Detail / basePath decodeDetail divisionName)
	(if Bug (princ (strcat "\nDecodeTargetPathDwf - Entered\n   parameters passed in Detail = " Detail "\n")))
	(if DevMark 
		(setq basePath (strcat TestPrmRootPath "Public\\"))
		(setq basePath (strcat PrmRootPath "Public\\"))
	)
	(cond
		((= Div "BH")
			(setq divisionName "Birmingham\\")
		)
		((= Div "E_")
			(setq divisionName "Birmingham\\")
		)
		((= Div "M_")
			(setq divisionName "Mobile\\")
		)
		((= Div "S_")
			(setq divisionName "Montgomery\\")
		)
		((= Div "SE")
			(setq divisionName "Montgomery\\")
		)
		((= Div "W_")
			(setq divisionName "Tuscaloosa\\")
		)
	)
	(cond
		((= Detail "DIST AREA MAP")
			(setq decodeDetail "DistArea\\")
		)
		((= Detail "FEEDER AREA MAP")
			(setq decodeDetail "Feeder\\")
		)
		((= Detail "SUB AREA MAP")
			(setq decodeDetail "Sub_Area\\")
		)
		((= Detail "SUBSINGLE MAP")
			(setq decodeDetail "SubSingle\\")
		)
		(T
			(setq decodeDetail "Other\\")
		)
	)
 					
	(setq Result (strcat basePath divisionName decodeDetail))
	(if Bug (princ "\nDecodeTargetPathDwf - Done\n"))
	(princ Result)
)

(defun UpCdtPths ( / saveDiv Fnam chkPth iniPth)
	(if Bug (princ "\nGet_Init.lsp!UpCdtPths - Entered\n"))
	
	;	Gets current division and saves it for later restore.
	(if (null Div)
		(DivGet)		; gets selected division from INI file.
	)
	(setq saveDiv Div)
	
	;	Setup and check ini file for incorrect path and rewrite paths if need.
	(setq	Fnam	(Find_INI))	; get path to INI file.
	(setq 	chkPth 	"S:\\WorkGroups\\APC Birmingham Division\\Division Mapping\\Cadet\\"
			iniPth	(dos_getini "CADET" "BH.DIVISION" fnam)
	)
	(if (= (substr iniPth 1 1) "*")
		(setq iniPth (substr iniPth 2))
	)
	(if (/= chkPth iniPth)
		(progn
			(dos_setini "CADET" "BH.DIVISION" chkPth fnam)
			(dos_setini "CADET" "E_.DIVISION" "S:\\WorkGroups\\APC Eastern Division\\Division Mapping\\Cadet\\" fnam)
			(dos_setini "CADET" "M_.DIVISION" "S:\\WorkGroups\\APC Mobile Division\\Division Mapping\\Cadet\\" fnam)
			(dos_setini "CADET" "S_.DIVISION" "S:\\WorkGroups\\APC Southern Division\\Division Mapping\\Cadet\\" fnam)
			(dos_setini "CADET" "SE.DIVISION" "S:\\WorkGroups\\APC SouthEast Division\\Division Mapping\\Cadet\\" fnam)
			(dos_setini "CADET" "W_.DIVISION" "S:\\WorkGroups\\APC Western Division\\Division Mapping\\Cadet\\" fnam)
		)
	)
	
	;	Restore Division in INI file.
	(UpdDivINI saveDiv)
)


