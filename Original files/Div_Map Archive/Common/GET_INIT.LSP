				(setq	_Path-Lisp		(strcat TestPrmRootPath "Adds30\\Lisp\\")
						_Path-LUT			(strcat TestPrmRootPath "Adds30\\LUT\\")
						_Path-Menu		(strcat TestPrmRootPath "Adds30\\Menu\\")
						_Path-Sym			(strcat TestPrmRootPath "Adds30\\Sym\\")
						_Path-DLG			(strcat TestPrmRootPath "Quad\\")
						_Alt_Path-Panel	(strcat TestPrmRootPath "DivData\\Shared Panels\\")
				)
			)
		)
	)
	(if	(and	DevMark
			Div
			(or	(= (StpDot AppNam) "ADDS")
				(= (StpDot AppNam) "ADDSPLOT")
				(= (StpDot AppNam) "BEMS")
