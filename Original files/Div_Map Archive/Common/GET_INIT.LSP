(defun Cb_Ok ( Act ValP DoLst / )				; Call Back function for PathDLG
	(cond
		((= Act 1) (setq	DoLst	(list ValP (nth 1 DoLst) (nth 2 DoLst))))
		((= Act 2) (setq	DoLst	(list (nth 0 DoLst) ValP (nth 2 DoLst))))
		((= Act 3) (setq	DoLst	(list (nth 0 DoLst) (nth 1 DoLst) ValP)))
		((null Act)(setq	DoLst	(list (get_tile "Lst1") (get_tile "Lst2") (get_tile "Str3"))))
	)
	(if (or		(= "" (get_tile "Lst1"))
				(= "0" (get_tile "Lst1"))
				(= " " (get_tile "Lst1"))
				(= "" (get_tile "Lst2"))
				(= "0" (get_tile "Lst2"))
				(= " " (get_tile "Lst2"))
				(< (strlen (get_tile "Str3")) 1)
		)
		(mode_tile "ok_button" 1)
		(mode_tile "ok_button" 0)
	)
	(if Bug
		(progn
			(if (or (= "" (get_tile "Lst1")) (= "0" (get_tile "Lst1")) (= " " (get_tile "Lst1")))
				(princ "\nBlank HdVal!")
				(princ (strcat "\n" (get_tile "Lst1") " HdVal!"))
			)
			(if (or (= "" (get_tile "Lst2")) (= "0" (get_tile "Lst2")) (= " " (get_tile "Lst2")))
				(princ "\nBlank NdVal!")
				(princ (strcat "\n" (get_tile "Lst2") " NdVal!"))
			)
			(if (< (strlen (get_tile "Str3")) 1)
				(princ "\nNot Over 0 NamVal!")
				(princ (strcat "\n" (get_tile "Str3") " NamVal!"))
			)
		)
	)
	DoLst
)

(defun DivSet ( Ch /	Bubba Cnt InData Hdr x	; Allows Selection of Division from parameter
					Fn F0 F1 Dsc Div_Lst
					DivINI DivNam TmpVal TmpDiv )
	(if Bug (princ "Entering DivSet!"))
	(setq	DivINI	(strcat _Path-Person "DIV_MAP.INI")
			Div_Lst	(list	"BH" "S_" "W_" "E_" "M_" "SE" "AL" "GA")
			TDiv		nil
			Div_Pth	(list	nil nil nil nil nil nil)
	)
	(if (findfile DivINI)
		(progn
			(if (setq TmpDiv (dos_getini (StpDot AppNam) (strcat "BH" ".DIVISION") DivINI))
				(if (= (substr TmpDiv 1 1) "*")
					(setq	Div_Pth	(RepLst Div_Pth (cons "BH" (substr TmpDiv 2)) 0)
							TDiv		0
					)
					(setq	Div_Pth	(RepLst Div_Pth (cons "BH" TmpDiv) 0))
				)
				(setq	Div_Pth	(RepLst Div_Pth (cons "BH" "") 0))
			)
			(if (setq TmpDiv (dos_getini (StpDot AppNam) (strcat "S_" ".DIVISION") DivINI))
				(if (= (substr TmpDiv 1 1) "*")
					(setq	Div_Pth	(RepLst Div_Pth (cons "S_" (substr TmpDiv 2)) 1)
							TDiv		1
					)
					(setq	Div_Pth	(RepLst Div_Pth (cons "S_" TmpDiv) 1))
				)
				(setq	Div_Pth	(RepLst Div_Pth (cons "S_" "") 1))
			)
			(if (setq TmpDiv (dos_getini (StpDot AppNam) (strcat "W_" ".DIVISION") DivINI))
				(if (= (substr TmpDiv 1 1) "*")
					(setq	Div_Pth	(RepLst Div_Pth (cons "W_" (substr TmpDiv 2)) 2)
							TDiv		2
					)
					(setq	Div_Pth	(RepLst Div_Pth (cons "W_" TmpDiv) 2))
				)
				(setq	Div_Pth	(RepLst Div_Pth (cons "W_" "") 2))
			)
			(if (setq TmpDiv (dos_getini (StpDot AppNam) (strcat "E_" ".DIVISION") DivINI))
				(if (= (substr TmpDiv 1 1) "*")
					(setq	Div_Pth	(RepLst Div_Pth (cons "E_" (substr TmpDiv 2)) 3)
							TDiv		3
					)
					(setq	Div_Pth	(RepLst Div_Pth (cons "E_" TmpDiv) 3))
				)
				(setq	Div_Pth	(RepLst Div_Pth (cons "E_" "") 3))
			)
			(if (setq TmpDiv (dos_getini (StpDot AppNam) (strcat "M_" ".DIVISION") DivINI))
				(if (= (substr TmpDiv 1 1) "*")
					(setq	Div_Pth	(RepLst Div_Pth (cons "M_" (substr TmpDiv 2)) 4)
							TDiv		4
					)
					(setq	Div_Pth	(RepLst Div_Pth (cons "M_" TmpDiv) 4))
				)
				(setq	Div_Pth	(RepLst Div_Pth (cons "M_" "") 4))
			)
			(if (setq TmpDiv (dos_getini (StpDot AppNam) (strcat "SE" ".DIVISION") DivINI))
				(if (= (substr TmpDiv 1 1) "*")
					(setq	Div_Pth	(RepLst Div_Pth (cons "SE" (substr TmpDiv 2)) 5)
							TDiv		5
					)
					(setq	Div_Pth	(RepLst Div_Pth (cons "SE" TmpDiv) 5))
				)
				(setq	Div_Pth	(RepLst Div_Pth (cons "SE" "") 5))
			)
			(setq	Dlg	2)
		)
	)
	(if (assoc Ch Div_Lst)
		(setq	Div			Ch
				DivINI		(strcat _Path-Person "DIV_MAP.INI")
				_Path-Div		(cdr (assoc Ch Div_Lst))
				_Path-Panel	_Path-Div
		)
		(progn
			(alert (strcat "***" AppNam " Error***\nNot a valid Division Choice!"))
			(exit)
		)
	)
	(if (assoc Ch Div_Lst)
		(setvar "USERS3" Div)
	)
	(cond	((= Div "AL") (princ "\nAlabama Control Center Selected"))
			((= Div "GA") (princ "\nGeorgia Control Center Selected"))
			((= Div "BH") (princ "\nBirmingham Division Selected"))
			((= Div "S_") (princ "\nSouthern Division Selected"))
			((= Div "W_") (princ "\nWestern Division Selected"))
			((= Div "E_") (princ "\nEastern Division Selected"))
			((= Div "N_") (princ "\nNorthern Division Selected"))
			((= Div "SE") (princ "\nSouth-Eastern Division Selected"))
	)
	(if (and (findfile DivINI) (not DevMark))
		(foreach	DivNam
				Div_Lst
				(if	(=	(substr	(setq	TmpVal	(dos_getini	(StpDot AppNam)
															(strcat (car DivNam) ".DIVISION")
															DivINI
												)
								)
								1
								1
						)
						"*"
					)
					(dos_setini (StpDot AppNam) (strcat (car DivNam) ".DIVISION") (substr TmpVal 2) DivINI)
				)
				(if (= (car DivNam) Ch)
					(if (= (substr TmpVal 1 1) "*")
						(dos_setini (StpDot AppNam) (strcat (car DivNam) ".DIVISION") TmpVal DivINI)
						(dos_setini (StpDot AppNam) (strcat (car DivNam) ".DIVISION") (strcat "*" TmpVal) DivINI)
					)
				)
		)
	)
	(Bld_T_Fdr)
	(if Bug (princ "Done with DivSet!"))
	(princ)
)

(defun DivGet ( /	Bubba Cnt InData Hdr x Fn F0	; Initial Call to INI file to find chosen Division
				F1 Dsc DivINI Div_Lst DivNam TmpVal )
	(if Bug (princ "\n{DivGet entered\n"))
	(setq	DivINI		(strcat _Path-Person "DIV_MAP.INI")
			Cnt			0
			Div			nil
			Div_Lst		(list "BH" "S_" "W_" "E_" "M_" "SE" "AL" "GA")
	)
	(if (findfile DivINI)
		(foreach	DivNam
				Div_Lst
				(if (setq TmpVal (dos_getini (StpDot AppNam) (strcat DivNam ".DIVISION") DivINI))
					(if	(= (substr TmpVal 1 1) "*")
						(setq	Div		DivNam
								Div_Lst	(RepLst Div_Lst (cons DivNam (substr TmpVal 2)) Cnt)
						)
						(setq	Div_Lst	(RepLst Div_Lst (cons DivNam TmpVal) Cnt))
					)
				)
				(setq	Cnt	(1+ Cnt))
		)
		(princ "\nDiv_Map.INI file not found!")
	)
	(if Div
		(progn
			(setq	_Path-Div		(cdr (assoc Div Div_Lst))
					_Path-Panel	_Path-Div
					Bubba		(setvar "USERS3" Div)
			)
			(cond	((= Div "AL") (princ "\nAlabama Control Center Selected"))
					((= Div "GA") (princ "\nGeorgia Control Center Selected"))
					((= Div "BH") (princ "\nBirmingham Division Selected"))
					((= Div "S_") (princ "\nSouthern Division Selected"))
					((= Div "W_") (princ "\nWestern Division Selected"))
					((= Div "E_") (princ "\nEastern Division Selected"))
					((= Div "N_") (princ "\nNorthern Division Selected"))
					((= Div "SE") (princ "\nSouth-Eastern Division Selected"))
			)
			(if Lst_Fd_C
				(Bld_T_Fdr)
			)
		)
		(progn
			(alert (strcat "***" AppNam " Error***\nNot a valid Division Default!"))
			(UpdDivINI nil)
		)
	)
	(if	(and	DevMark
			Div
			(or	(= (StpDot AppNam) "ADDS")
				(= (StpDot AppNam) "ADDSPLOT")
				(= (StpDot AppNam) "BEMS")
				(wcmatch (StpDot AppNam) "CADET##")
				(= (StpDot AppNam) "SUBTOOLS")
				(wcmatch (StpDot AppNam) "ADDS##")
			)
		)
		(DivDevGet Div)
	)
	(if Bug (princ "\nDivGet exited}\n"))
	(princ)
)

