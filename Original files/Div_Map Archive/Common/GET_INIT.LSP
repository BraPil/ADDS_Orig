		(if DevMark
			(cond
				((= NewApp "CADET")
					(setq	S::StartUp	nil)
					(setq	IsGood	(GetProf "CADET20_T"))
					(if IsGood
						(progn
							(load "S:\\Workgroups\\APC Power Delivery\\Division Mapping Test\\Cadet20\\MENU\\Cadet20_T.mnl")
