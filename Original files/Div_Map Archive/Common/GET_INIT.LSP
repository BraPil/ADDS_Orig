(defun Find_INI ( /	Pth_INI _Path-INI		; Finds INI file and returns path
					Old_Drv Old_Dir )
	(if Bug (princ "\nLocating INI file, please wait..."))
	(if Bug (Twaddle 0 20))
	
	(setq	Pth_INI	(list (findfile "C:\\DIV_MAP\\DIV_MAP.INI")))
	
	(if Pth_INI
		(setq	_Path-Person	(dos_splitpath (car Pth_INI)))
		(cond														;If the INI file is not found
			((member "C:" (dos_drives))
				(if Bug (princ "\nLocating INI file version not 3 or 4"))
				(setq	_Path-Person	"C:")
				(if (member "DIV_MAP" (mapcar (quote strcase) (dos_subdir _Path-Person)))
					(setq	_Path-Person	(strcat _Path-Person "\\DIV_MAP\\"))
					(progn
						(if (/= (dos_drive) "C:")
							(setq	Old_Drv	(dos_drive)
									Bubba	(dos_drive "C:")
							)
							(setq	Old_Drv	nil)
						)
						(if (/= (dos_pwdir) "C:\\")
							(setq	Old_Dir	(dos_pwdir)
									Bubba	(dos_chdir "C:\\")
							)
							(setq	Old_Dir	nil)
						)
						(dos_mkdir "\\DIV_MAP")
						(setq	_Path-Person	(strcat _Path-Person "\\DIV_MAP\\"))
						(if Old_Dir
							(setq	Bubba	(dos_chdir Old_Dir))
						)
						(if Old_Drv
							(setq	Bubba	(dos_drive Old_Drv))
						)
					)
				)
			)
		)
	)
	(if Bug (Twaddle 20 20))
	(if _Path-Person
		(if Pth_INI
			(setq	_Path-INI		(car Pth_INI)
					_Path-Person	(strcat (nth 0 _Path-Person) (nth 1 _Path-Person))
			)
			(setq	_Path-INI		nil)
		)
		(setq	_Path-INI		nil)
	)
	(if Bug (Twaddle -40 40))
	_Path-INI
)

