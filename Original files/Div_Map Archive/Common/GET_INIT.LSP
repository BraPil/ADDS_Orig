(defun TstPth ( DrvInf /	GoodDrv Drv Sub	; Path Test function to validate Paths in Call Back
						Fil Ext SubLen SubTst
						SubLst Cnt Strt Bubba )
	(setq	GoodDrv	T
			Drv		(nth 0 DrvInf)
			Sub		(nth 1 DrvInf)
			Fil		(nth 2 DrvInf)
			Ext		(nth 3 DrvInf)
			Drv		(strcat Drv (substr Sub 1 1))
	)
	(if (and Bug Drv) (princ (strcat "\nDrive: " Drv)))
	(if (and Bug Sub) (princ (strcat "\nSub: " Sub)))
	(if (< (strlen Sub) 2)
		(setq	Sub		nil)
		(setq	Sub		(substr Sub 2)
				SubLen	(strlen Sub)
				SubTst	Drv
				SubLst	(mapcar (quote strcase) (dos_subdir SubTst))
				Cnt		1
				Strt		1
		)
	)
	(if (not (member (substr Drv 1 2) (mapcar (quote strcase) (dos_drives))))
		(setq	GoodDrv	nil
				Bubba	(if Bug (princ "\nDrive is Bad!"))
		)
		(if Bug (princ "\nDrive is Good!"))
	)
	(if Bug (princ "\nTesting Path..."))
	(if Sub
		(while (<= Cnt SubLen)
			(if	(and	(/= Cnt 1)
					(= (substr Sub Cnt 1) "\\")
				)
				(setq	Psub		(substr Sub Strt (- Cnt Strt))
						Strt		(1+ Cnt)
				)
				(setq	Psub		nil)
			)
			(if (and Bug Psub) (princ (strcat "\nPsub:" Psub " Strt:" (itoa Strt) " Cnt:" (itoa Cnt)"!")))
			(if Psub
				(if GoodDrv
					(if (not (member (strcase Psub) SubLst))
						(setq	GoodDrv		nil)
						(setq	Bubba	(if Bug (princ (strcat "\nTested " Psub " Good!")))
								SubTst	(strcat SubTst Psub "\\")
								Bubba	(if Bug (princ (strcat "\nSubTst:" SubTst)))
								SubLst	(mapcar (quote strcase) (dos_subdir SubTst))
								Psub		nil
						)
					)
				)
			)
			(setq	Cnt	(1+ Cnt))
		)
	)
	GoodDrv
)

(defun Cb_Lst ( Act ValP DoLst / IsGood Pth )	; Call Back - INI path tester
	(cond
		((or(= (StpDot AppNam) "CADET20") (=(StpDot AppNam) "CADET"))
			(if (and (>= Act 0) (<= Act 8))
				(progn
					(setq	IsGood	T)
					(if (not (TstPth (dos_splitpath ValP)))
						(setq	IsGood	nil)
					)
					(if IsGood
						(mode_tile "ok_button" 0)
						(mode_tile "ok_button" 1)
					)
					(if Bug
						(if IsGood
							(princ "\nIts Good!")
							(princ "\nIts No Good!")
						)
					)
					(if IsGood
						(setq	DoLst	(RepLst DoLst ValP Act))
						(set_tile (strcat "Pth" (itoa (1+ Act))) (nth Act DoLst))
					)
				)
				(setq	DoLst	DoLst)
			)
			(if (null Act)
				(progn
					(set_tile "Pth1" (nth 0 PthLst))
					(set_tile "Pth2" (nth 1 PthLst))
					(set_tile "Pth3" (nth 2 PthLst))
					(set_tile "Pth4" (nth 3 PthLst))
					(set_tile "Pth5" (nth 4 PthLst))
					(set_tile "Pth6" (nth 5 PthLst))
					(set_tile "Pth7" (nth 6 PthLst))
					(set_tile "Pth8" (nth 7 PthLst))
					(set_tile "Pth9" (nth 8 PthLst))
					(setq	IsGood	T)
					(foreach	Pth
							DoLst
							(if IsGood
								(if (not (TstPth (dos_splitpath Pth)))
									(setq	IsGood	nil)
								)
							)
					)
					(if IsGood
						(mode_tile "ok_button" 0)
						(mode_tile "ok_button" 1)
					)
					(if Bug
						(if IsGood
							(princ "\nIts Good!")
							(princ "\nIts No Good!")
						)
					)
				)
			)
		)
		((= (strcase (substr AppNam 1 5)) "ADDS ")
			(if (and (>= Act 0) (<= Act 13))
				(progn
					(setq	IsGood	T)
					(if (not (TstPth (dos_splitpath ValP)))
						(setq	IsGood	nil)
					)
					(if IsGood
						(mode_tile "ok_button" 0)
						(mode_tile "ok_button" 1)
					)
					(if Bug
						(if IsGood
							(princ "\nIts Good!")
							(princ "\nIts No Good!")
						)
					)
					(if IsGood
						(setq	DoLst	(RepLst DoLst (strcase ValP) Act)
								Bubba	(set_tile (strcat "Pth" (itoa (1+ Act))) (nth Act DoLst))
						)
						(set_tile (strcat "Pth" (itoa (1+ Act))) (nth Act DoLst))
					)
				)
				(setq	DoLst	DoLst)
			)
			(if (null Act)
				(progn
					(set_tile "Pth1" (nth 0 PthLst))
					(set_tile "Pth2" (nth 1 PthLst))
					(set_tile "Pth3" (nth 2 PthLst))
					(set_tile "Pth4" (nth 3 PthLst))
					(set_tile "Pth5" (nth 4 PthLst))
					(set_tile "Pth6" (nth 5 PthLst))
					(set_tile "Pth7" (nth 6 PthLst))
					(set_tile "Pth8" (nth 7 PthLst))
